#!/usr/bin/bash

DISK0="$(realpath /dev/disk/by-id/nvme-nvme.1e4b-30303335363230303030303532-4e452d3154422032323432-00000001)"
DISK1="$(realpath /dev/disk/by-id/nvme-eui.e8238fa6bf530001001b448b47f32f0c)"
BOOT="${DISK0}p1"
ROOT="${DISK0}p2"
AUX="${DISK1}p1"
UUID="$(lsblk -dno UUID /dev/mapper/root)"

sed -i -e '/^#en_US.UTF-8/s/^#//' -e '/^#ar_EG.UTF-8/s/^#//' /etc/locale.gen
locale-gen
printf '%s\n' 'LANG=en_US.UTF-8' | tee /etc/locale.conf

ln -f -s /usr/share/zoneinfo/Asia/Riyadh /etc/localtime
hwclock -u -w

printf '%s\n' 'KEYMAP=us' 'FONT=default8x16' | tee /etc/vconsole.conf

printf '%s\n' 'aeiedamo' | tee /etc/hostname

sed -i -e '/^#NoExtract/s/$/ boot\/intel-ucode.img/' -e '/^#NoExtract/s/^#//' -e '/^#Color/s/^#//' -e '/^#Verbose/a DisableDownloadTimeout' -e '/^#Verbose/s/^#//' -e '/^#\[core\|^#\[extra\|^#\[multilib/,+1s/^#//' /etc/pacman.conf
printf '%s\n' 'Server = https://mirror.pkgbuild.com/$repo/os/$arch' 'Server = https://fastly.mirror.pkgbuild.com/$repo/os/$arch' | tee /etc/pacman.d/mirrorlist
sed -i -e '/^#MAKEFLAGS/s/=.*$/="-j8"/' -e '/^#MAKEFLAGS/s/^#//' -e '/^#BUILDDIR/s/^#//' -e '/^OPTIONS/s/debug/!&/' /etc/makepkg.conf

sed -i -e '/^HOOKS/s/systemd/& plymouth btrfs/' -e '/^HOOKS/s/keymap //' -e '/^HOOKS/s/filesystems/sd-encrypt &/' /etc/mkinitcpio.conf

pacman -Syu --needed --noconfirm linux linux-headers linux-lts linux-lts-headers alsa-firmware alsa-utils linux-firmware linux-tools-meta intel-ucode guestfs-tools plymouth qemu-full qemu-user-static-binfmt snap-pac sof-firmware sbctl wireless-regdb base-devel bash-completion bees devtools firejail iwd modemmanager networkmanager noto-fonts noto-fonts-cjk noto-fonts-emoji noto-fonts-extra nvme-cli pipewire-alsa pipewire-jack ttf-cascadia-code ttf-noto-nerd zram-generator gdm gnome-control-center virt-manager 7zip alacarte android-tools arch-wiki-docs ardour baobab bluez-cups bluez-utils btrfs-assistant calf cdrtools celluloid chrony cronie crun cups-pdf dconf-editor distrobox dnsmasq easyeffects edk2-shell efibootmgr ethtool evolution-ews evolution-spamassassin fail2ban fastfetch fd file-roller firefox-i18n-ar firewall-applet flatpak-xdg-utils foliate fzf ghostty gimp github-cli gnome-backgrounds gnome-browser-connector gnome-characters gnome-console gnome-firmware gnome-keyring gnome-remote-desktop gnome-shell-extension-appindicator gnome-software gnome-themes-extra gnome-tweaks gnome-user-share gparted gst-plugins-bad gst-plugins-ugly gst-plugin-va gst-thumbnailers gvfs-afc gvfs-dnssd gvfs-gphoto2 gvfs-mtp gvfs-nfs gvfs-onedrive gvfs-smb gvfs-wsdd hunspell-en_us inetutils intel-media-sdk jdk-openjdk kdenlive libappindicator libayatana-appindicator libreoffice-fresh-ar loupe lsp-plugins-lv2 malcontent man-db mda.lv2 mission-center nm-connection-editor net-tools networkmanager-l2tp networkmanager-pptp nss-mdns obs-studio onnxruntime-cpu obsidian orca papers podman proton-vpn-gtk-app qalculate-gtk qbittorrent qt6ct qt6-multimedia-gstreamer radvd ripgrep rnote rust rygel samba seahorse smartmontools snapshot swtpm system-config-printer telegram-desktop throttled tlp-pd tlp-rdw tlpui tmux trash-cli unrar usb_modeswitch vulkan-intel wl-clipboard yt-dlp zam-plugins-lv2 zip

sbctl create-keys
sbctl enroll-keys
sbctl sign -s /boot/vmlinuz-linux
sbctl sign -s /boot/vmlinuz-linux-lts
sbctl sign -s -o /usr/lib/systemd/boot/efi/systemd-bootx64.efi.signed /usr/lib/systemd/boot/efi/systemd-bootx64.efi
sbctl sign -s -o /usr/lib/fwupd/efi/fwupdx64.efi.signed /usr/lib/fwupd/efi/fwupdx64.efi
sbctl sign -s /usr/share/edk2-shell/x64/Shell_Full.efi

printf '%s%s%s %s%s%s %s %s%s %s %s %s\n' 'rd.luks.name=' "$(lsblk -dno UUID ${ROOT})" '=root' 'rd.luks.name=' "$(lsblk -dno UUID ${AUX})" '=aux' 'rd.luks.options=tpm2-device=/dev/tpmrm0' 'root=UUID=' "${UUID}" 'rw rootflags=compress=zstd,subvol=/@' 'lsm=landlock,lockdown,yama,integrity,apparmor,bpf intel_iommu=on iommu=pt' 'quiet splash' | tee /etc/kernel/cmdline

bootctl install --variables=no
printf '%s\t%s\n' 'default' '@saved' | tee /boot/loader/loader.conf
printf '%s\t%s\n' 'title' 'Arch Linux' 'sort-key' '0' 'linux' '/vmlinuz-linux' 'initrd' '/initramfs-linux.img' 'options' "$(cat /etc/kernel/cmdline)" | tee /boot/loader/entries/arch-linux.conf
printf '%s\t%s\n' 'title' 'Arch Linux LTS' 'sort-key' '1' 'linux' '/vmlinuz-linux-lts' 'initrd' '/initramfs-linux-lts.img' 'options' "$(cat /etc/kernel/cmdline)" | tee /boot/loader/entries/arch-linux-lts.conf

cp /usr/share/edk2-shell/x64/Shell_Full.efi /boot/shellx64.efi

mv /opt/configs/pacman.d/hooks/ /etc/pacman.d/

mv /etc/bees/beesd.conf.sample /etc/bees/beesd.conf
sed -i -e "/^UUID/s/=.*$/=${UUID}/" -e '/^# DB_SIZE/s/^# //' /etc/bees/beesd.conf

printf '%s\n' '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' | tee /etc/sudoers.d/01-wheel

printf '%s\n' 'polkit.addRule(function(action, subject) { if (subject.isInGroup("wheel")) { return polkit.Result.YES; }});' | tee /etc/polkit-1/rules.d/01-wheel.rules

passwd root

useradd -c 'AlaEldin Mohamed' -G audio,disk,kvm,libvirt,log,storage,wheel -m am
passwd am

sed -i -e '/SA/s/^#//' /etc/conf.d/wireless-regdom

printf '%s\n' 'options psmouse synaptics_intertouch=1' | tee /etc/modprobe.d/psmouse.conf

printf '%s\n' '[zram0]' 'zram-size=ram' 'compression-algorithm=zstd' | tee /etc/systemd/zram-generator.conf

mkdir -p /etc/systemd/logind.conf.d/
printf '%s\n' '[Login]' 'HandleLidSwitch=ignore' 'HandleLidSwitchExternalPower=ignore' | tee /etc/systemd/logind.conf.d/lid.conf

sed -i -e '/^#MulticastDNS/s/yes/no/' -e '/^#MulticastDNS/s/^#//' /etc/systemd/resolved.conf

printf '%s\n' 'ListenAddress aeiedamo.local' | tee /etc/ssh/sshd_config.d/01-local.conf

printf '%s\n' "export EDITOR='vim' VISUAL='vim'" | tee /etc/profile.d/01-editor.sh

printf '%s\n' 'export XDG_CONFIG_HOME="${HOME}/.config" XDG_DATA_HOME="${HOME}/.local/share" XDG_STATE_HOME="${HOME}/.local/state"' | tee /etc/profile.d/02-xdg.sh

printf '%s\n' 'export XDG_DATA_DIRS="${XDG_DATA_DIRS}:/var/lib/flatpak/exports/share:${XDG_DATA_HOME}/flatpak/exports/share"' | tee /etc/profile.d/03-flatpak.sh

printf '%s\n' "export QT_QPA_PLATFORMTHEME='qt6ct'" | tee /etc/profile.d/04-qt.sh

cp /etc/skel/.bash_profile /root/
cp /etc/skel/.bashrc /root/

sed -i -e '/^PS1\b/d' /root/.bashrc
printf '%s\n' "PS1=' \[\e[92;1;4m\]⮜ \A | \u | \w | \$? ⮞\[\e[0m\] '" | tee -a /root/.bashrc

printf '%s\n' '"\e[A": history-search-backward' '"\e[B": history-search-forward' '' 'set bell-style none' 'set echo-control-characters off' 'set show-all-if-ambiguous on' 'set colored-stats on' 'set visible-stats on' 'set mark-symlinked-directories on' 'set completion-ignore-case on' 'set completion-map-case on' 'set colored-completion-prefix on' 'set menu-complete-display-prefix on' 'set revert-all-at-newline on' '$if Bash' 'Tab: menu-complete' '$endif' | tee -a /root/.inputrc

printf '%s\n' '[uefi_capsule]' 'DisableShimForSecureBoot=true' | tee -a /etc/fwupd/fwupd.conf

sed -i -e '/^hosts/s/resolve \[\!UNAVAIL=return\]/mdns_minimal \[NOTFOUND=return\]/g' -e '/^hosts/s/$/& libvirt libvirt_guest' /etc/nsswitch.conf

printf '%s\n' '[main]' 'dns=systemd-resolved' | tee /etc/NetworkManager/conf.d/dns.conf
printf '%s\n' '[device]' 'wifi.backend=iwd' | tee /etc/NetworkManager/conf.d/wifi_backend.conf

mv /opt/configs/fonts/local.conf /etc/fonts/

sed -i -e '/^PercentageLow/s/=.*$/=10.0/' -e '/^CriticalPowerAction/s/HybridSleep/PowerOff/' /etc/UPower/UPower.conf

mv /opt/configs/tlp.d/01-main.conf /etc/tlp.d/

mkdir -p /etc/X11/xorg.conf.d
printf '%s\n\t%s\n\t%s\n\t%s\n\t%s\n\t%s\n\t%s\n%s\n' 'Section "InputClass"' 'Identifier "system-keyboard"' 'MatchIsKeyboard "on"' 'Option "XkbLayout" "us,eg"' 'Option "XkbModel" "pc104"' 'Option "XkbVariant" ","' 'Option "XkbOptions" "grp:win_space_toggle"' 'EndSection' | tee /etc/X11/xorg.conf.d/00-keyboard.conf

printf '%s\n' 'user-db:user' 'system-db:gdm' 'file-db:/usr/share/gdm/greeter-dconf-defaults' | tee /etc/dconf/profile/gdm

mkdir -p /etc/dconf/db/gdm.d/
printf '%s\n' '[org/gnome/desktop/interface]' "font-name='Sans 10'" | tee /etc/dconf/db/gdm.d/01-font
printf '%s\n' '[org/gnome/desktop/interface]' 'show-battery-percentage=true' | tee /etc/dconf/db/gdm.d/02-battery-percentage
printf '%s\n' '[org/gnome/desktop/interface]' "accent-color='yellow'" | tee /etc/dconf/db/gdm.d/03-accent-color
printf '%s\n' '[org/gnome/login-screen]' "logo=''" | tee /etc/dconf/db/gdm.d/04-logo
printf '%s\n' '[org/gnome/gnome-session]' 'logout-prompt=false' | tee /etc/dconf/db/gdm.d/05-logout-prompt

dconf update

printf '%s\n' 'pref("general.config.filename", "firefox.cfg");' 'pref("general.config.obscure_value", 0);' | tee /usr/lib/firefox/defaults/pref/autoconfig.js
mv /opt/configs/firefox/firefox.cfg /usr/lib/firefox/

rm -f -r /opt/configs

printf '%s\n' '--cookies-from-browser firefox -f "bv+ba/b" -S "ext" -o "${HOME}/Videos/%(webpage_url_domain)s/%(id)s-%(title)s.%(ext)s"' | tee /etc/yt-dlp.conf

systemctl mask systemd-rfkill.service systemd-rfkill.socket

systemctl enable apparmor.service avahi-daemon.service beesd@${UUID}.service bluetooth.service chronyd.service cronie.service cups.service fail2ban.service firewalld.service fstrim.timer fwupd-refresh.timer gdm.service gnome-remote-desktop.service libvirtd.service ModemManager.service NetworkManager.service sshd.service systemd-boot-update.service systemd-resolved.service throttled.service tlp.service tlp-pd.service virtnetworkd.service virtnodedevd.service virtqemud.service virtstoraged.service
